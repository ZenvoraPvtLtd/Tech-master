# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Use the database name: techmaster
MONGODB_URI=mongodb://localhost:27017/techmaster

# Authentication Secrets
JWT_SECRET=your_jwt_access_token_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URLs for CORS configuration
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
